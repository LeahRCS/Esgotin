datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          Int           @id @default(autoincrement())
  username    String        @unique
  password    String
  displayName String        @default("Rato Operario")
  role        UserRole      @default(WORKER)
  status      String        @default("desempregado")
  createdAt   DateTime      @default(now())

  applications  Application[]
  postedJobs    Job[]         @relation("PostedJobs")
  notifications Notification[]
}

enum UserRole {
  WORKER
  CORPORATE
  ADMIN
}

model Job {
  id            Int        @id @default(autoincrement())
  code          String     @unique // "#TOX-882"
  companyName   String
  title         String
  salary        String     // "R$ 1.200 (PJ + Mimos)"
  description   String     @db.Text
  requirements  String     @db.Text
  tags          String[]   // ["INSALUBRIDADE MÁXIMA", "ZERO BENEFÍCIOS"]
  status        JobStatus  @default(ACTIVE)
  toxicityLevel Int        @default(100)
  createdAt     DateTime   @default(now())

  postedBy   User          @relation("PostedJobs", fields: [postedById], references: [id])
  postedById Int

  applications Application[]
}

enum JobStatus {
  PENDING_MODERATION
  ACTIVE
  FILLED
  DECOMPOSING
  CLOSED
}

model Application {
  id              Int               @id @default(autoincrement())
  coverLetter     String            @db.Text
  status          ApplicationStatus @default(PENDING)
  rhResponse      String?           @db.Text
  exploitability  Int               @default(0)
  debtLevel       String?
  vitalStatus     String?
  socialDeathDate DateTime?
  createdAt       DateTime          @default(now())

  applicant   User @relation(fields: [applicantId], references: [id])
  applicantId Int

  job   Job @relation(fields: [jobId], references: [id])
  jobId Int
}

enum ApplicationStatus {
  PENDING
  EXPLOITED
  REJECTED
  DECOMPOSING
}

model Notification {
  id        Int      @id @default(autoincrement())
  message   String   @db.Text
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id])
  userId Int
}
